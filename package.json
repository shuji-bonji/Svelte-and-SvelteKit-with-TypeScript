{
  "name": "svelte-typescript-guide",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npx pagefind --site dist --force-language ja",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint:articles": "npm run lint:articles:extract && npm run lint:articles:eslint && npm run lint:articles:report",
    "lint:articles:extract": "node scripts/extract-svelte-blocks.mjs",
    "lint:articles:eslint": "eslint .tmp-eslint-check --format json --output-file .tmp-eslint-check/_results.json || true",
    "lint:articles:report": "node scripts/eslint-svelte-blocks-report.mjs eslint-svelte-blocks-report.md"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.0.0",
    "@vite-pwa/sveltekit": "^1.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "mdsvex": "^0.12.7",
    "pagefind": "^1.5.2",
    "shiki": "^4.0.2",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "dependencies": {
    "mermaid": "^11.14.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0"
  }
}
